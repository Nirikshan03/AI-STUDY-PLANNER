pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                echo '>>> Pulling code from GitHub...'
                checkout scm
            }
        }

        stage('Build Backend') {
            steps {
                dir('AI-study-planner/backend') {      // ← ADD AI-study-planner/
                    sh 'chmod +x mvnw'
                    sh './mvnw clean package -DskipTests'
                }
            }
        }

        stage('Run Tests') {
            steps {
                dir('AI-study-planner/backend') {      // ← ADD AI-study-planner/
                    sh './mvnw test'
                }
            }
            post {
                always {
                    junit allowEmptyResults: true,
                          testResults: 'AI-study-planner/backend/target/surefire-reports/*.xml'
                }
            }
        }

        stage('Build Docker Images') {
            steps {
                dir('AI-study-planner') {              // ← ADD AI-study-planner/
                    sh 'docker compose build backend frontend'
                }
            }
        }

        stage('Deploy') {
            steps {
                dir('AI-study-planner') {              // ← ADD AI-study-planner/
                    sh 'docker compose up -d --force-recreate postgres'
                    sh 'sleep 10'
                    sh 'docker compose up -d --force-recreate backend'
                    sh 'sleep 5'
                    sh 'docker compose up -d --force-recreate frontend'
                }
            }
        }
    }

    post {
        success { echo '✅ SUCCESS — App live at http://localhost:3000' }
        failure { echo '❌ FAILED — Check console output' }
    }
}